# qBittorrent WebUI
QBIT_URL=http://localhost:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=changeme
QBIT_TAG=book

# Docker path remapping.
# qBittorrent (running in Docker) reports container paths. Map them to paths
# reachable from the host where this program runs. Comma-separated container=host
# pairs; the longest matching prefix wins.
# Example: in the container downloads live at /downloads, on the host at /mnt/user/downloads
PATH_MAP=/downloads=/mnt/user/downloads,/data=/mnt/user/data

# Calibre
# CALIBRE_LIBRARY is the path to your Calibre library folder (the one with metadata.db).
CALIBRE_LIBRARY=/mnt/user/calibre
CALIBREDB_BIN=calibredb
# Add even if Calibre thinks the book is a duplicate.
ADD_DUPLICATES=false

# Hardcover API (https://hardcover.app/account/api). The "Bearer " prefix is optional.
HARDCOVER_TOKEN=
HARDCOVER_URL=https://api.hardcover.app/v1/graphql

# Daemon
POLL_INTERVAL=5m
STATE_FILE=state.json
DRY_RUN=false
